#!/bin/sh
#
# Pre-commit hook: verify formatting with dprint.
# Activate with: just setup

if ! command -v dprint >/dev/null 2>&1; then
    echo "error: dprint not found. Install it: https://dprint.dev/install/"
    exit 1
fi

if ! dprint check; then
    echo ""
    echo "Formatting check failed. Run 'dprint fmt' to fix."
    exit 1
fi
