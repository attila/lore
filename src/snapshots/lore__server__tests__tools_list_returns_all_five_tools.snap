---
source: src/server.rs
expression: resp
---
{
  "id": 2,
  "jsonrpc": "2.0",
  "result": {
    "tools": [
      {
        "description": "Search the knowledge base for software patterns, conventions, and preferences. Use this before implementing new code to check for established patterns. Returns ranked results with source provenance.",
        "inputSchema": {
          "properties": {
            "include_metadata": {
              "default": false,
              "description": "When true, appends a `lore-metadata` fenced code block to the end of the response containing machine-readable JSON with per-row rank/source_file/score and a top-level mode field ('hybrid' | 'fts_fallback' | 'fts_only'). Defaults to false. Opt-in because the fenced block bloats the response and most callers only need the human-readable prose.",
              "type": "boolean"
            },
            "query": {
              "description": "Natural language search query",
              "type": "string"
            },
            "top_k": {
              "description": "Number of results to return (default: from config)",
              "type": "number"
            }
          },
          "required": [
            "query"
          ],
          "type": "object"
        },
        "name": "search_patterns"
      },
      {
        "description": "Create a new pattern in the knowledge base. Use only when the user explicitly asks to save, record, or document a pattern. Creates a markdown file and indexes it; the change is committed to git when the knowledge base is a git repository, otherwise the file is written without a commit.",
        "inputSchema": {
          "properties": {
            "body": {
              "description": "Pattern content in markdown",
              "type": "string"
            },
            "include_metadata": {
              "default": false,
              "description": "When true, appends a `lore-metadata` fenced code block to the end of the response containing machine-readable JSON with the written file path, chunk count, and commit status. Defaults to false.",
              "type": "boolean"
            },
            "tags": {
              "description": "Optional tags for categorisation. Passing `\"universal\"` opts the pattern into the always-on injection tier — its body is emitted at every SessionStart and bypasses PreToolUse deduplication (see docs/pattern-authoring-guide.md §\"When to use the universal tag\").",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "title": {
              "description": "Pattern title (used as filename and heading)",
              "type": "string"
            }
          },
          "required": [
            "title",
            "body"
          ],
          "type": "object"
        },
        "name": "add_pattern"
      },
      {
        "description": "Replace the content of an existing pattern. Use only when the user explicitly asks to update or rewrite a pattern. Overwrites the file and re-indexes; the change is committed to git when the knowledge base is a git repository, otherwise the file is written without a commit.",
        "inputSchema": {
          "properties": {
            "body": {
              "description": "New pattern content in markdown (replaces existing body)",
              "type": "string"
            },
            "include_metadata": {
              "default": false,
              "description": "When true, appends a `lore-metadata` fenced code block to the end of the response containing machine-readable JSON with the updated file path, chunk count, and commit status. Defaults to false.",
              "type": "boolean"
            },
            "source_file": {
              "description": "Relative path of the file to update (from search results)",
              "type": "string"
            },
            "tags": {
              "description": "Optional. Omit to preserve the existing frontmatter tags (including `universal`). Pass an empty array `[]` to clear all tags. Pass a non-empty array to replace the tag list wholesale; include `\"universal\"` to keep or opt the pattern into the always-on injection tier.",
              "items": {
                "type": "string"
              },
              "type": "array"
            }
          },
          "required": [
            "source_file",
            "body"
          ],
          "type": "object"
        },
        "name": "update_pattern"
      },
      {
        "description": "Add a new section to an existing pattern without replacing it. Use when the user wants to add examples, edge cases, or notes to an existing pattern. Appends a heading and body and re-indexes; the change is committed to git when the knowledge base is a git repository, otherwise the file is written without a commit.",
        "inputSchema": {
          "properties": {
            "body": {
              "description": "Content to append under the heading",
              "type": "string"
            },
            "heading": {
              "description": "Heading for the new section",
              "type": "string"
            },
            "include_metadata": {
              "default": false,
              "description": "When true, appends a `lore-metadata` fenced code block to the end of the response containing machine-readable JSON with the updated file path, chunk count, and commit status. Defaults to false.",
              "type": "boolean"
            },
            "source_file": {
              "description": "Relative path of the file to append to (from search results)",
              "type": "string"
            }
          },
          "required": [
            "source_file",
            "heading",
            "body"
          ],
          "type": "object"
        },
        "name": "append_to_pattern"
      },
      {
        "description": "Report knowledge base health: whether it is a git repository, the indexed chunk and source counts, the last ingested commit (if any), whether the inbox branch workflow is configured, and whether a .loreignore file is active (filtering files out of the index). Use this before write operations to verify the knowledge base is in the expected state, especially when the agent needs to know whether changes will be committed to git or whether files in a particular path are excluded from search.",
        "inputSchema": {
          "properties": {
            "include_metadata": {
              "default": false,
              "description": "When true, appends a `lore-metadata` fenced code block to the end of the response containing machine-readable JSON with knowledge_dir, git_repository, last_ingested_commit, chunks_indexed, sources_indexed, inbox_workflow_configured, delta_ingest_available, and loreignore_active fields. Defaults to false.",
              "type": "boolean"
            }
          },
          "required": [],
          "type": "object"
        },
        "name": "lore_status"
      }
    ]
  }
}
